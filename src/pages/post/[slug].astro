---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import {
  posts,
  getPostBySlug,
  getNextPost,
  getPrevPost,
  getRecommendedPosts,
} from "../../data/posts";

export async function getStaticPaths() {
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

export const prerender = false; // Renderiza bajo demanda, no estáticamente

const { slug } = Astro.params;
const post = getPostBySlug(slug);

// Si no existe el post, redirige a inicio
if (!post) {
  return Astro.redirect("/");
}

const nextPost = getNextPost(post.id);
const prevPost = getPrevPost(post.id);
const recommendedPosts = getRecommendedPosts(post.id);
---

<!-- <BaseLayout title={`${post.title} - Huellas de Barrio`}> -->
 <BaseLayout
  title={`${post.title} - Huellas de Barrio`}
  description={post.introduction}
  image={`https://popular-esmedellin.com${post.image}`}
  url={`https://popular-esmedellin.com/post/${post.slug}`}
/>
  <Header currentPage="post" />

  <main>
    <!-- Banner -->
    <div
      class="container-fluid"
      style="
        background: linear-gradient(135deg, #004200 0%, #006600 100%);
        min-height: 120px;
        display: flex;
        align-items: center;
        justify-content: center;
      "
    >
      <div class="container ">
        <div class="row w-100">
          <div class="col-2 d-flex align-items-center justify-content-center">
            <a href={`/post/${prevPost.slug}`} class="text-decoration-none">
              <i
                class="fas fa-chevron-left text-white nav-chevron"
                style="font-size: 2rem; cursor: pointer"></i>
            </a>
          </div>
          <div class="col-8 text-center text-white">
            <a href="/" style="text-decoration: none; color: white">
              <h2 class="fw-bold mb-2">{post.title}</h2>
            </a>
            <p class="mb-0">{post.subtitle}</p>
          </div>
          <div class="col-2 d-flex align-items-center justify-content-center">
            <a href={`/post/${nextPost.slug}`} class="text-decoration-none">
              <i
                class="fas fa-chevron-right text-white nav-chevron"
                style="font-size: 2rem; cursor: pointer"></i>
            </a>
          </div>
        </div>
      </div>
    </div>

<div class="container-fluid  bg-dark-subtle">

    <!-- Post -->
    <div class="container py-5 ">
      <div class="col-lg-12 ">
        {
          post.images && post.images.length > 0 ? (
            post.images.map((imgSrc, index) => (
              <img
                src={imgSrc}
                alt={`Imagen ${index + 1} del post`}
                class="w-100 mb-4"
                key={index}
                style="height: 350px;top:100px ; object-fit: cover;"
              />
            ))
          ) : (
            <img
              src={post.image}
              alt="Imagen del post"
              class="w-100 mb-4"
              style="height: 150px; object-fit: cover;"
            />
          )
        }
      </div>

      <div class="row gy-4">
        <!-- Columna izquierda: contenido -->
        <div class="col-lg-8">
          <article class="bg-white p-4 rounded shadow-sm">
            <p class="text-muted mb-4">
              <small
                >Publicado el <strong>{post.date}</strong> ·
                <strong>Autor:</strong>
                {post.author}</small
              >
            </p>

            <h3 class="text-success mb-3">Introducción</h3>
            <p class="fs-5" style="color: #333">
              {post.introduction}
            </p>

            <h4 class="text-success mt-4">{post.contextTitle}</h4>
            <p style="color: #555">
              {post.context}
            </p>

            <blockquote
              class="blockquote ps-3 border-start border-3 border-success"
            >
              <p class="mb-0">
                "{post.quote}"
              </p>
              <footer class="blockquote-footer mt-2" style="background-color: #004e2a8a;color:white;">{post.quoteAuthor}</footer>
            </blockquote>

            <h4 class="text-success mt-4">Conclusión</h4>
            <p style="color: #555">
              {post.conclusion}
            </p>
          </article>
        </div>

        <!-- Columna derecha: meta info -->
        <aside class="col-lg-4">
          <div class="bg-white p-4 rounded shadow-sm mb-4">
            <h5 class="text-success mb-3">Detalles</h5>
            <ul class="list-unstyled mb-0">
              <li class="mb-2"><strong>Fecha:</strong> {post.date}</li>
              <li class="mb-2"><strong>Autor:</strong> {post.author}</li>
              <li class="mb-2"><strong>Categoría:</strong> {post.category}</li>
              <li><strong>Lectura:</strong> {post.readTime}</li>
            </ul>
          </div>

          <div class="bg-white p-4 rounded shadow-sm mb-4">
            <h5 class="text-success mb-3">Etiquetas</h5>
            <div class="d-flex flex-wrap gap-2">
              {
                post.tags.map((tag) => (
                  <span class="badge bg-success">{tag}</span>
                ))
              }
            </div>
          </div>

          <div class="bg-white p-4 rounded shadow-sm">
            <h5 class="text-success mb-3">Recomendados</h5>
            <ul class="list-unstyled mb-0">
              {
                recommendedPosts.map((recPost) => (
                  <li class="mb-2">
                    <a
                      href={`/post/${recPost.slug}`}
                      class="text-dark text-decoration-none"
                    >
                      {recPost.title}
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>
        </aside>
      </div>

      <div class="col-lg-12 my-4 comments">
        <div class="bg-white p-4 rounded shadow-sm">
          <h5 class="text-success mb-3">Comentarios</h5>
          <div
            class="fb-comments"
            data-href={`https://popular-esmedellin.com/post/${post.slug}`}
            data-width="100%"
            data-numposts="5"
          >
          </div>
        </div>
      </div>
    </div>
</div>

  </main>

  <Footer />
</BaseLayout>

<style>
  .nav-chevron {
    transition: transform 0.3s ease;
  }

  .nav-chevron:hover {
    transform: scale(1.3);
  }
</style>

<script>
  // Facebook SDK initialization
  if (typeof window !== "undefined") {
    (function (d, s, id) {
      var js,
        fjs = d.getElementsByTagName(s)[0];
      if (d.getElementById(id)) return;
      js = d.createElement(s);
      js.id = id;
      js.src =
        "https://connect.facebook.net/en_US/sdk.js#xfbml=1&version=v18.0&autoLogAppEvents=1";
      fjs.parentNode?.insertBefore(js, fjs);
    })(document, "script", "facebook-jssdk");
  }
</script>
