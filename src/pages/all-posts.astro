---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { posts } from '../data/posts';
---

<BaseLayout title="Todos los Posts - Huellas de Barrio">
  <Header currentPage="actualidades" />

  <main>
    <div class="container-fluid" style="background: linear-gradient(135deg, #004200 0%, #006600 100%); min-height: 100px; display: flex; align-items: center; justify-content: center;">
      <a href="#" style="text-decoration: none;"><h2 class="text-white m-0">Todos los posts (modelo completo)</h2></a>
    </div>

    <div class="container py-5   ">
      {posts.map((post) => (
        <article key={post.slug} class="mb-5 p-4 border rounded shadow-sm">
          <h2 class="text-success">{post.title}</h2>
          <p class="text-muted">{post.date} · {post.author} · {post.category} · {post.readTime}</p>
          <p>{post.subtitle}</p>

          <div class="row gy-3 mb-4">
            {post.images && post.images.length > 0 ? (
              post.images.map((img, idx) => (
                <div class="col-md-12" key={idx}>
                  <img src={img} alt={`Imagen ${idx + 1} de ${post.title}`} class="w-100" style="height: 250px; object-fit: cover; border-radius: 0.5rem;" />
                </div>
              ))
            ) : (
              <div class="col-12">
                <img src={post.image} alt={`Imagen de ${post.title}`} class="w-100" style="height: 150px; object-fit: cover; border-radius: 0.5rem;" />
              </div>
            )}
          </div>

          <section class="mb-3">
            <h3>{post.contextTitle}</h3>
            <p>{post.introductionContent}</p>
          </section>


          <section class="mb-3">
            <p>{post.contextContent}</p>
          </section>

          <section class="mb-3">
            <p>{post.textoSecundario}</p>
          </section>

          
          <div class="mt-3">
            {post.tags.map((tag) => (
            <a href="../index.html" style="text-decoration: none;">  <span class="badge bg-success me-1" key={tag}>{tag}</span> </a>
            ))}
          </div>
        </article>
      ))}

      
    </div>

    

  </main>

  <Footer />
</BaseLayout>
